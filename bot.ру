import os
import threading
from flask import Flask
import telebot

TOKEN = os.environ.get("TELEGRAM_BOT_TOKEN")

bot = telebot.TeleBot(TOKEN)
app = Flask(__name__)

@bot.message_handler(commands=["start"])
def start(message):
    bot.send_message(
        message.chat.id,
        "🎯  Привет, Слава! Я бот проекта AI Ставки. Я запущен и готов работать."
    )

@bot.message_handler(func=lambda message: True)
def echo(message):
    bot.send_message(
        message.chat.id,
        "Я на связи. Пока умею только отвечать, следующий этап — подключим линию."
    )

@app.route("/")
def home():
    return "AI Ставки bot is running"

def run_bot():
    bot.infinity_polling()

if __name__ == "__main__":
    threading.Thread(target=run_bot).start()
    app.run(host="0.0.0.0", port=int(os.environ.get("PORT", 10000)))
